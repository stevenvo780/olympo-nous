              { "key": "x-tenant-id", "value": "{{x_tenant_id}}" },
              { "key": "x-source", "value": "hermes" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event_type\": \"order.paid\",\n  \"data\": {\n    \"order\": { \"id\": \"ord_123\", \"total\": 100.5 },\n    \"store\": { \"owner\": { \"email\": \"owner@example.com\" } }\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/webhooks/hermes", "host": ["{{base_url}}"], "path": ["webhooks", "hermes"] }
          }
        }
