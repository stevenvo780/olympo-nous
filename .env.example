# Environment variables for Nous (Hub Central)
NODE_ENV=development
PORT=3007

# Database configuration
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=prizma
DB_PASSWORD=password
DB_NAME=nous

# Redis configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Ecosystem APIs configuration
HERMES_API_URL=http://localhost:3000
HERMES_API_KEY=your_hermes_api_key

IRIS_API_URL=http://localhost:3001
IRIS_API_KEY=your_iris_api_key

TALARIA_API_URL=http://localhost:3006
TALARIA_API_KEY=your_talaria_api_key

PISTIS_API_URL=http://localhost:3002
PISTIS_API_KEY=your_pistis_api_key

TALANTON_API_URL=http://localhost:3003
TALANTON_API_KEY=your_talanton_api_key

LOGOS_API_URL=http://localhost:3004
LOGOS_API_KEY=your_logos_api_key

# Si deseas que Nous firme las peticiones a Logos, configura este secreto.
# Debe coincidir con HUB_WEBHOOK_SECRET en el servicio Logos.
# Si no se define, Nous omitirá el header x-hub-signature (comportamiento recomendado por defecto).
LOGOS_HUB_WEBHOOK_SECRET=


# Security
JWT_SECRET=your_jwt_secret_for_nous
API_SECRET=your_nous_api_secret

# Prizma Nous API Key (debe coincidir con hermes-backend)
PRIZMA_NOUS_SECRET=hermes-backend-secret-key-2024

# Webhook security
WEBHOOK_SECRET=your_webhook_secret

# Logging
LOG_LEVEL=debug
